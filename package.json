{
  "name": "draw-works",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx scripts/seed.ts",
    "setup": "npm run db:push && npm run db:seed",
    "vercel-build": "if [ -n \"$DATABASE_URL\" ] && [ \"$DATABASE_URL\" != \"file:./data/drawworks.db\" ]; then npm run db:push && npm run db:seed; fi && next build"
  },
  "dependencies": {
