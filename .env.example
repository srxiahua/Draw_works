# Database (SQLite)
# 本地：file:./data/drawworks.db
# Vercel 生产推荐 Turso：https://turso.tech → Vercel Integration 一键接入
DATABASE_URL=file:./data/drawworks.db
# Turso 远程库需额外填写（Vercel 接入 Turso 后会自动注入）
# TURSO_AUTH_TOKEN=

# 单人站点（可选，用于区分本地用户记录）
# OWNER_EMAIL=owner@local.drawworks
# OWNER_NAME=创作者

# App URL（AI 需通过此地址访问缩略图，生产环境填公网域名）
NEXT_PUBLIC_APP_URL=http://localhost:3000

# AI Provider: auto | local | mimo | qwen | zhipu | doubao
# auto = 优先云端 AI，失败时自动本地图像分析兜底
AI_PROVIDER=auto

# 小米 Mimo（OpenAI 兼容）
MIMO_API_KEY=
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5

# 通义千问 (DashScope compatible mode)
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_VISION_MODEL=qwen-vl-max

# 智谱 GLM-4V
# ZHIPU_API_KEY=
# ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# ZHIPU_VISION_MODEL=glm-4v-flash

# 豆包视觉
# DOUBAO_API_KEY=
# DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# DOUBAO_VISION_MODEL=doubao-1-5-vision-pro

# Storage: local (dev) | vercel-blob (Vercel 生产) | oss (阿里云)
STORAGE_DRIVER=local

# Vercel Blob（部署到 Vercel 时由平台自动注入，本地无需填写）
# BLOB_READ_WRITE_TOKEN=

# Phase 3 — Aliyun OSS (optional)
# OSS_REGION=
# OSS_BUCKET=
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=
